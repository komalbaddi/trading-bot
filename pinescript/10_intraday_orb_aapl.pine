//@version=5
// =============================================================================
// STRATEGY 10: INTRADAY OPENING RANGE BREAKOUT + VWAP  (tuned for AAPL)
// Best intraday performer in a real-data test of AAPL (5m & 15m, 60 days):
// ORB with a VWAP trend filter had the highest profit factor (~2 on 15-min)
// and smallest drawdown, and it survives realistic slippage because it trades
// only ~once per day.
//
// >>> RECOMMENDED TIMEFRAME: 15-MINUTE (beat 5-min on AAPL in testing). <<<
//
// Logic:
//   * Mark the high/low of the first N minutes after the open (the "opening range").
//   * Go long if price breaks above the range high AND is above VWAP (trend filter).
//   * Stop = opposite side of the range (or ATR); target = RR x risk.
//   * One trade per day, flat by the close (no overnight risk).
//
// CAVEAT: validated on a SMALL sample (~30 trades). Paper-trade before trusting it.
// =============================================================================
strategy("10 Intraday ORB + VWAP (AAPL)",
     overlay              = true,
     initial_capital      = 10000,
     default_qty_type     = strategy.fixed,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.0,      // Alpaca commission-free
     slippage             = 2,        // ticks; keep this — intraday costs are real
     pyramiding           = 0)

// ---------- Inputs ----------
orbMin    = input.int(15,  "Opening range minutes", group="Signal", minval=1)
useVwap   = input.bool(true,"Require price above VWAP (long) / below (short)", group="Signal")
rr        = input.float(2.0,"Reward:Risk (target)",  group="Risk", step=0.1)
useAtrStop= input.bool(false,"Stop uses ATR instead of range edge", group="Risk")
atrLen    = input.int(14,  "ATR length",             group="Risk")
atrMult   = input.float(1.5,"ATR stop x",            group="Risk", step=0.1)
riskPct   = input.float(1.0,"Risk % of equity per trade", group="Risk", step=0.1)
maxLev    = input.float(1.0,"Max leverage (notional / equity)", group="Risk", step=0.5)
maxTrades = input.int(1,   "Max entries per day",    group="Signal")

sess      = input.session("0930-1600","Regular session", group="Session")
tz        = input.string("America/New_York","Timezone", group="Session")
allowLong = input.bool(true, "Allow Longs",  group="Direction")
allowShort= input.bool(false,"Allow Shorts", group="Direction")

// ---------- Session + opening range ----------
inSess     = not na(time(timeframe.period, sess, tz)) and timeframe.isintraday
newSession = inSess and not inSess[1]
sessEnd    = inSess[1] and not inSess

var float orH = na
var float orL = na
var int   startT = na
var int   tradesToday = 0

if newSession
    orH := high
    orL := low
    startT := time
    tradesToday := 0

building = inSess and not na(startT) and (time - startT) < orbMin * 60 * 1000
if building
    orH := math.max(orH, high)
    orL := math.min(orL, low)

orReady = inSess and not building and not na(orH)

// ---------- Indicators ----------
vwapVal = ta.vwap(hlc3)
atr     = ta.atr(atrLen)

// ---------- Signals ----------
lastBar = inSess and not na(startT)
longSig  = allowLong  and orReady and tradesToday < maxTrades and ta.crossover(close, orH)  and (not useVwap or close > vwapVal)
shortSig = allowShort and orReady and tradesToday < maxTrades and ta.crossunder(close, orL) and (not useVwap or close < vwapVal)

// ---------- Sizing + orders ----------
longStopPx  = useAtrStop ? close - atr * atrMult : orL
shortStopPx = useAtrStop ? close + atr * atrMult : orH
longRisk    = close - longStopPx
shortRisk   = shortStopPx - close
riskCash    = strategy.equity * (riskPct / 100.0)
capShares   = close > 0 ? (strategy.equity * maxLev) / close : 0

if longSig and longRisk > 0 and strategy.position_size == 0
    qty = math.min(riskCash / longRisk, capShares)
    strategy.entry("L", strategy.long, qty=qty)
    strategy.exit("L-x", from_entry="L", stop=longStopPx, limit=close + longRisk * rr)
    tradesToday += 1

if shortSig and shortRisk > 0 and strategy.position_size == 0
    qty = math.min(riskCash / shortRisk, capShares)
    strategy.entry("S", strategy.short, qty=qty)
    strategy.exit("S-x", from_entry="S", stop=shortStopPx, limit=close - shortRisk * rr)
    tradesToday += 1

// flat by the close — no overnight risk
if sessEnd
    strategy.close_all(comment="EOD flat")

// ---------- Plots ----------
plot(orReady ? orH : na, "OR High", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(orReady ? orL : na, "OR Low",  color=color.new(color.red, 0),   style=plot.style_linebr, linewidth=2)
plot(vwapVal, "VWAP", color=color.new(color.purple, 0), linewidth=2)
bgcolor(building ? color.new(color.yellow, 85) : na)
bgcolor(not inSess ? color.new(color.gray, 94) : na)
