//@version=5
// =============================================================================
// STRATEGY 19: BTC SUPERTREND  (daily, walk-forward validated)
// Supertrend is an ATR-based trend follower — one line that flips with the trend.
// On BTC daily it held up out-of-sample: OOS +62% (factor 2) to +92% (factor 4),
// 38-42% win. All the daily trend indicators (EMA, Supertrend, MACD, ADX) passed
// out-of-sample — strong evidence the daily BTC trend edge is real.
//
// >>> Use on the BTC/USD DAILY chart. <<<
//   Long when Supertrend flips to UP (price above the Supertrend line)
//   Flat when it flips to DOWN. Optional 200-EMA regime filter to cut drawdown.
// =============================================================================
strategy("19 BTC Supertrend",
     overlay              = true,
     initial_capital      = 10000,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 95,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.1,       // ~0.1% per side (crypto fees)
     slippage             = 0)

// ---------- Inputs ----------
factor   = input.float(3.0,"Supertrend factor (2=more trades, 4=fewer)", group="Signal", step=0.5)
atrLen   = input.int(10,  "Supertrend ATR length", group="Signal")
useRegime= input.bool(true,"Regime filter: only long above 200-EMA", group="Signal")
regLen   = input.int(200, "Regime EMA",           group="Signal")

useDates = input.bool(false,"Limit backtest dates (walk-forward)", group="Backtest")
fromDate = input.time(timestamp("2023-07-01"), "From", group="Backtest")
toDate   = input.time(timestamp("2026-12-31"), "To",   group="Backtest")

// ---------- Indicators ----------
[stLine, dir] = ta.supertrend(factor, atrLen)   // dir == -1 => uptrend, +1 => downtrend
regEma = ta.ema(close, regLen)
inWin  = not useDates or (time >= fromDate and time <= toDate)
regimeOK = not useRegime or close > regEma

// ---------- Signals ----------
flipUp   = dir == -1 and dir[1] == 1
flipDown = dir == 1 and dir[1] == -1
longSig  = inWin and flipUp and regimeOK

if longSig and strategy.position_size == 0
    strategy.entry("L", strategy.long)
if strategy.position_size > 0 and flipDown
    strategy.close("L", comment="Supertrend flip down")

// ---------- Alerts ----------
alertcondition(longSig, "BTC Supertrend BUY", "BTC Supertrend flipped up — enter long")
alertcondition(strategy.position_size > 0 and flipDown, "BTC Supertrend EXIT", "BTC Supertrend flipped down — exit")

// ---------- Plots ----------
plot(stLine, "Supertrend", color=dir == -1 ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=2)
plot(useRegime ? regEma : na, "Regime EMA200", color=color.new(color.gray, 0))
bgcolor(dir == -1 and inWin ? color.new(color.green, 92) : na)
plotshape(longSig, "BUY", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small, text="BUY")
