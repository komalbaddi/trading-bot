//@version=5
// =============================================================================
// STRATEGY 16: BTC/USD TREND FOLLOWING  (walk-forward validated)
// The best result in this whole project: optimized 2016-2021, forward-tested 2021-2026,
// it BEAT buy & hold on BOTH return AND drawdown out-of-sample:
//   OOS: +115% (vs HODL +84%),  max drawdown 41% (vs HODL 77%).
// It works by exiting downtrends (dodging crashes like 2022) and riding uptrends.
//
// Crypto FLIPS the stock playbook: on AAPL mean-reversion won & trend failed; on BTC
// TREND wins & mean-reversion LOSES. Use on the BTC/USD DAILY chart.
//
//   Entry: EMA20 crosses ABOVE EMA50 (trend turns up)
//   Exit : trailing stop = highest-high-since-entry - 7*ATR,  OR  EMA20 crosses below EMA50
//   Long / flat (fully in BTC or fully in cash). Long-only — do not short.
//
// WARNING: ~38% win rate — MANY small losses, few big wins. Psychologically hard to
// hold to. 41% drawdown is still large. This is the edge, but only if you can stick to it.
// =============================================================================
strategy("16 BTC Trend Following",
     overlay              = true,
     initial_capital      = 10000,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 100,       // all-in long/flat (matches the backtest)
     commission_type      = strategy.commission.percent,
     commission_value     = 0.1,       // ~0.1% per side (crypto spread/fees)
     slippage             = 0)

// ---------- Inputs ----------
fastLen  = input.int(20,  "Fast EMA",            group="Signal")
slowLen  = input.int(50,  "Slow EMA",            group="Signal")
atrLen   = input.int(14,  "ATR length",          group="Risk")
initMult = input.float(3.0,"Initial stop = ATR x",group="Risk", step=0.5)
trailMult= input.float(7.0,"Trailing stop = ATR x",group="Risk", step=0.5)
useRegime= input.bool(true,"Regime filter: only enter above the 200-EMA (cuts drawdown)", group="Signal")
regLen   = input.int(200, "Regime EMA length",   group="Signal")

useDates = input.bool(false,"Limit backtest dates (for walk-forward testing)", group="Backtest")
fromDate = input.time(timestamp("2021-07-01"), "From", group="Backtest")
toDate   = input.time(timestamp("2026-12-31"), "To",   group="Backtest")

// ---------- Indicators ----------
eF  = ta.ema(close, fastLen)
eS  = ta.ema(close, slowLen)
atr = ta.atr(atrLen)
inWin = not useDates or (time >= fromDate and time <= toDate)

// ---------- Signals ----------
regEma    = ta.ema(close, regLen)
longSig   = inWin and ta.crossover(eF, eS) and (not useRegime or close > regEma)
crossDown = ta.crossunder(eF, eS)

if longSig and strategy.position_size == 0
    strategy.entry("L", strategy.long)

// ---------- Exit: chandelier trail (highest high SINCE ENTRY) + EMA cross-down ----------
var float hiSinceEntry = na
var float longStop      = na

if strategy.position_size > 0
    if strategy.position_size[1] == 0
        hiSinceEntry := high
        longStop     := strategy.position_avg_price - atr * initMult
    else
        hiSinceEntry := math.max(hiSinceEntry, high)
        longStop     := math.max(longStop, hiSinceEntry - atr * trailMult)
    strategy.exit("Exit", from_entry="L", stop=longStop)
    if crossDown
        strategy.close("L", comment="EMA cross down")
else
    hiSinceEntry := na
    longStop     := na

// ---------- Alerts ----------
alertcondition(longSig, "BTC Trend BUY", "BTC EMA20 crossed above EMA50 — enter long / buy BTC")
alertcondition(strategy.position_size > 0 and crossDown, "BTC Trend EXIT", "BTC trend turned down — exit / sell BTC")

// ---------- Plots ----------
plot(eF, "EMA20", color=color.new(color.aqua, 0), linewidth=2)
plot(eS, "EMA50", color=color.new(color.orange, 0), linewidth=2)
plot(useRegime ? regEma : na, "Regime EMA200", color=color.new(color.gray, 0), linewidth=1)
plot(strategy.position_size > 0 ? longStop : na, "Trailing stop", color=color.new(color.fuchsia, 0), style=plot.style_linebr, linewidth=2)
bgcolor(eF > eS and inWin ? color.new(color.green, 92) : na)
plotshape(longSig, "BUY", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small, text="BUY")
