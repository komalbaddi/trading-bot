//@version=5
// =============================================================================
// STRATEGY 9: TUNED DAILY SWING BREAKOUT  (EMA regime + 50-day breakout + 5xATR trail)
// This is the winner of a 7-symbol parameter sweep (AAPL/MSFT/NVDA/SPY/QQQ/AMZN/GOOGL).
// Profit factor 2.5-5.8, tiny drawdowns (2-7%). Long-only, Daily chart.
//
// Tuned parameters (vs the earlier version):
//   * ENTRY: 50-day high breakout (not pullback) while in an uptrend
//   * TRAIL: 5x ATR (wider) tracking highest-high-since-entry -> lets winners run
//   * REMOVED the "exit below 50-EMA" rule -> it was cutting trends short
//   * Date filter defaults ON from 2015 (avoids penny-price backtest artifacts)
//
// NOTE: designed to REDUCE RISK (2-7% drawdown), not to beat buy & hold on strong
// trends. Always compare its return AND drawdown to "Buy & Hold" in the tester.
// =============================================================================
strategy("09 Tuned Swing Breakout",
     overlay              = true,
     initial_capital      = 10000,
     default_qty_type     = strategy.fixed,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.0,
     slippage             = 1,
     pyramiding           = 0)

// ---------- Inputs (tuned defaults) ----------
brkLen   = input.int(50,  "Breakout: N-day high", group="Signal")
emaMid   = input.int(50,  "Mid EMA (alignment)",  group="Signal")
emaTrend = input.int(200, "Trend EMA (regime)",   group="Signal")
emaFastL = input.int(20,  "Fast EMA (alignment)", group="Signal")

atrLen   = input.int(14,  "ATR length",            group="Risk")
atrInit  = input.float(2.5,"Initial stop = ATR x", group="Risk", step=0.1)
chMult   = input.float(6.0,"Trailing stop = ATR x",group="Risk", step=0.1)  // walk-forward optimum (5-6 equivalent)
riskPct  = input.float(1.5,"Risk % of equity per trade", group="Risk", step=0.1)
maxLev   = input.float(1.0,"Max leverage (notional / equity)", group="Risk", step=0.5)

useDates = input.bool(true, "Limit backtest to realistic era (recommended)", group="Backtest")
fromDate = input.time(timestamp("2015-01-01"), "From", group="Backtest")

// ---------- Indicators ----------
eF = ta.ema(close, emaFastL)
eM = ta.ema(close, emaMid)
eT = ta.ema(close, emaTrend)
atr = ta.atr(atrLen)

inWindow  = not useDates or time >= fromDate
upRegime  = close > eT and eF > eM
priorHigh = ta.highest(high, brkLen)[1]          // highest high of the prior N bars
longSig   = inWindow and upRegime and close > priorHigh

// ---------- Sizing ----------
stopDist = atr * atrInit
riskCash = strategy.equity * (riskPct / 100.0)
qty      = math.min(stopDist > 0 ? riskCash / stopDist : 0, close > 0 ? (strategy.equity * maxLev) / close : 0)

if longSig and strategy.position_size == 0 and qty > 0
    strategy.entry("L", strategy.long, qty=qty)

// ---------- Exit: fixed chandelier trail (highest high SINCE ENTRY) + regime flip ----------
var float hiSinceEntry = na
var float longStop      = na

if strategy.position_size > 0
    if strategy.position_size[1] == 0
        hiSinceEntry := high
        longStop     := strategy.position_avg_price - stopDist
    else
        hiSinceEntry := math.max(hiSinceEntry, high)
        longStop     := math.max(longStop, hiSinceEntry - atr * chMult)
    strategy.exit("Exit", from_entry="L", stop=longStop)
    if close < eT
        strategy.close("L", comment="regime flip")
else
    hiSinceEntry := na
    longStop     := na

// ---------- Plots ----------
plot(eF, "EMA20",  color=color.new(color.aqua,   0))
plot(eM, "EMA50",  color=color.new(color.yellow, 0))
plot(eT, "EMA200", color=color.new(color.red,    0), linewidth=2)
plot(strategy.position_size > 0 ? longStop : na, "Trailing stop", color=color.new(color.fuchsia, 0), style=plot.style_linebr, linewidth=2)
bgcolor(upRegime and inWindow ? color.new(color.green, 93) : na)
plotshape(longSig, "Breakout", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small)
